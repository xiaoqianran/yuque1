# Copy to monorepo ROOT as `.env` (never commit real secrets):
#   cp .env.example .env
#
# Prisma / API 会从「仓库根 .env」或「apps/api/.env」加载 DATABASE_URL。
#
# 与 deploy/compose/docker-compose.yml 本地默认账号一致时，取消下一行注释即可：
# DATABASE_URL=postgresql://yuque:localdevonly@localhost:5432/yuque1?schema=public
DATABASE_URL=postgresql://yuque:localdevonly@localhost:5432/yuque1?schema=public
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-with-long-random-string-at-least-32-chars
SESSION_TTL_DAYS=7
SMS_PROVIDER=mock
# 本地联调固定验证码（仅 mock）；不设置则随机 6 位并打日志
SMS_MOCK_CODE=123456
# 单测可设 KV_DRIVER=memory 强制内存 KV
# KV_DRIVER=memory
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
BODY_MD_MAX_BYTES=2097152
LOG_LEVEL=info
API_PORT=3000

# --- Vite dev（apps/web，读仓库根 .env）---
# Host 头白名单：all | true | * = 允许任意（本地 / code-server 域名反代默认）
# 收紧示例：VITE_ALLOWED_HOSTS=localhost,127.0.0.1,code-sg.example.com
VITE_ALLOWED_HOSTS=all
# 可选：dev server 端口、/api 代理目标（同容器默认 127.0.0.1:3000）
# VITE_DEV_PORT=5173
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
#
# code-server Ports 默认 https://host/proxy/5173/
# - 配置会把 VSCODE_PROXY_URI 解析为 base=/proxy/5173/（与面板 URL 一致，禁止改成 absproxy）
# - 中间件会补回 /proxy 剥掉的前缀，避免白屏与双重路径 /proxy/5173/absproxy/5173/
# VSCODE_PROXY_URI=https://code-sg.example.com/proxy/{{port}}/
# 显式覆盖：VITE_BASE=/proxy/5173/
# VITE_HMR_HOST=code-sg.example.com
# VITE_HMR_CLIENT_PORT=443
# VITE_HMR_PROTOCOL=wss
