# Copy to .env for local API (never commit real secrets)
# Replace USER/PASSWORD with local credentials
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/yuque1?schema=public
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-with-long-random-string-at-least-32-chars
SESSION_TTL_DAYS=7
SMS_PROVIDER=mock
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
BODY_MD_MAX_BYTES=2097152
LOG_LEVEL=info
API_PORT=3000
